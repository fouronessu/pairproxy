# ==============================================================================
# cproxy.yaml — c-proxy 客户端配置示例
#
# 用途：在开发者本地机器运行，拦截 Claude Code 等 code agent 的请求，
#       注入用户 JWT，转发给 s-proxy 集群。
#
# 默认配置文件路径：
#   Windows: %APPDATA%\pairproxy\cproxy.yaml
#   Linux:   ~/.config/pairproxy/cproxy.yaml
#   macOS:   ~/Library/Application Support/pairproxy/cproxy.yaml
#
# 使用方式：
#   cproxy start --config /path/to/cproxy.yaml
#   或将文件放到默认路径后直接执行 cproxy start
# ==============================================================================


# ------------------------------------------------------------------------------
# listen — 本地监听地址（Claude Code 把这里当作 API Base URL）
# ------------------------------------------------------------------------------
listen:
  host: "127.0.0.1"   # 仅本地监听，不对外暴露
  port: 8080           # Claude Code 配置：ANTHROPIC_BASE_URL=http://127.0.0.1:8080


# ------------------------------------------------------------------------------
# sproxy — s-proxy 连接配置
# ------------------------------------------------------------------------------
sproxy:
  # primary: 初始种子节点地址（sp-1 的公网/内网地址）。
  # c-proxy 启动时首先连接此节点；通过响应头中的路由表更新自动感知其他节点。
  # 可选：若 targets 列表或 routing-cache.json 已有节点，可省略此项。
  primary: "http://proxy.company.com:9000"

  # targets: 已知 s-proxy worker 节点地址列表（静态配置，主节点故障兜底）。
  #
  # 三来源合并策略（启动顺序）：
  #   1. sproxy.primary       — 种子节点（最高优先级）
  #   2. sproxy.targets       — 静态 worker 列表（本字段）
  #   3. routing-cache.json   — 上次运行时持久化的路由表（兜底）
  #
  # 三个来源的地址按 Addr 去重后合并到负载均衡器。
  # 配置文件中出现的地址始终标记为 Healthy:true；
  # 仅从缓存加载的地址保留上次的健康状态。
  #
  # 典型使用场景：
  #   - 公司有 sp-1（主）、sp-2、sp-3（worker），在此列出 sp-2/sp-3，
  #     则即使 sp-1 宕机，c-proxy 也能继续转发请求到 sp-2/sp-3。
  #
  # 单节点部署时可省略（留空列表或删除此字段）。
  targets:
    - "http://proxy2.company.com:9000"   # 已知 worker 节点 2
    # - "http://proxy3.company.com:9000"  # 已知 worker 节点 3（按需取消注释）

  # lb_strategy: 对 s-proxy 节点的负载均衡策略
  # 可选：round_robin（默认）| random | least_conn | weighted
  lb_strategy: "round_robin"

  # health_check_interval: 主动健康检查间隔（对各 s-proxy 节点 GET /health）
  # 格式支持 Go duration：30s / 1m / 5m 等
  health_check_interval: 30s

  # request_timeout: 单个请求的超时时间（含 SSE 流式响应）
  # 建议 >= 5m，因为 LLM 流式响应可能很长
  request_timeout: 300s

  # ---- 改进项3：健康检查增强 ----
  # health_check_timeout: 单次主动健康检查的超时时间（默认 3s）
  health_check_timeout: 3s

  # health_check_failure_threshold: 连续失败多少次后将节点标记为不健康（默认 3）
  health_check_failure_threshold: 3

  # health_check_recovery_delay: 节点被熔断后，多久自动恢复为健康状态（默认 60s）
  # 0 = 禁用自动恢复（需等待主动健康检查通过）
  health_check_recovery_delay: 60s

  # passive_failure_threshold: 被动熔断阈值——请求失败多少次后触发熔断（默认 3）
  passive_failure_threshold: 3

  # ---- 改进项4：路由表主动发现 ----
  # shared_secret: 与 s-proxy 集群通信的共享密钥（用于 /cluster/routing-poll 鉴权）
  # 与 sproxy.yaml 中 cluster.shared_secret 保持一致；空串=禁用主动轮询
  # shared_secret: "${CLUSTER_SECRET}"

  # routing_poll_interval: 主动轮询路由表的间隔（默认 60s；0=禁用）
  # 轮询时若路由表无变化，s-proxy 返回 304，不消耗带宽
  routing_poll_interval: 60s

  # ---- 改进项5：请求级重试 ----
  retry:
    # enabled: 是否启用非流式请求的自动重试（默认 true）
    enabled: true
    # max_retries: 最大重试次数（不含首次请求，默认 2）
    max_retries: 2
    # retry_on_status: 触发重试的 HTTP 状态码（默认 [502, 503, 504]）
    # 注意：流式请求（stream: true）不走重试路径
    retry_on_status: [502, 503, 504]


# ------------------------------------------------------------------------------
# auth — 本地 JWT 令牌管理
# ------------------------------------------------------------------------------
auth:
  # token_dir: 存储登录令牌（token.json）的目录
  # 支持 ~ 开头的路径展开
  # 默认与配置文件同目录（即 DefaultConfigDir()）
  token_dir: "~/.config/pairproxy"   # Linux/macOS
  # token_dir: "%APPDATA%/pairproxy"  # Windows（由程序自动处理）

  # auto_refresh: 是否在令牌接近过期时自动刷新（始终为 true，无需修改）
  auto_refresh: true

  # refresh_threshold: access token 剩余有效期低于此阈值时触发自动刷新
  refresh_threshold: 30m


# ------------------------------------------------------------------------------
# log — 日志配置
# ------------------------------------------------------------------------------
log:
  # level: 日志级别
  # 可选：debug | info | warn | error
  # 生产环境建议 info；调试连接问题时用 debug
  level: "info"

  # debug_file: 双向转发内容 debug 日志文件路径（可选，默认不启用）
  # 启用后，每条请求的两个方向（← 客户端请求、← s-proxy 响应 chunk）
  # 均以 DEBUG 级别写入该文件，敏感 header 自动过滤，body 截断至 64 KB。
  # 变更后需重启 cproxy 生效（cproxy 不支持 SIGHUP 热重载）。
  # debug_file: "~/.config/pairproxy/debug.log"
