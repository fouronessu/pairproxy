# ==============================================================================
# sproxy-worker.service — systemd unit for pairproxy s-proxy (worker node)
#
# 与 sproxy.service 的区别：
#   - 配置文件指向 sproxy-worker.yaml（cluster.role = worker）
#   - EnvironmentFile 指向 sproxy-worker.env
#   - SyslogIdentifier 区分为 sproxy-worker
#
# 安装步骤与 sproxy.service 相同，替换对应文件名即可。
# 参考 sproxy.service 文件头部注释。
# ==============================================================================

[Unit]
Description=PairProxy s-proxy worker node — enterprise LLM API gateway
Documentation=https://github.com/l17728/pairproxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/sproxy start --config /etc/pairproxy/sproxy-worker.yaml
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s
TimeoutStopSec=30s

User=pairproxy
Group=pairproxy

EnvironmentFile=/etc/pairproxy/sproxy-worker.env

WorkingDirectory=/var/lib/pairproxy

StandardOutput=journal
StandardError=journal
SyslogIdentifier=sproxy-worker

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/pairproxy /var/log/pairproxy
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallFilter=@system-service
SystemCallFilter=~@debug @mount @reboot @swap @privileged
SystemCallErrorNumber=EPERM

LimitNOFILE=65536
LimitCORE=0

[Install]
WantedBy=multi-user.target
