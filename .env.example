# docker-compose 环境变量示例
# 复制为 .env 并填入真实值（.env 已在 .gitignore 中，不会提交）

# Anthropic API Key（支持多 key，配置文件中用 ${ANTHROPIC_API_KEY_1} 引用）
ANTHROPIC_API_KEY_1=sk-ant-api03-replace-me

# JWT 签名密钥（生产环境建议 32+ 字符随机字符串）
# 生成：openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret

# Admin 面板密码的 bcrypt hash
# 生成：docker run --rm -it pairproxy/sproxy hash-password
# 或编译后：./bin/sproxy hash-password
ADMIN_PASSWORD_HASH=$2a$10$replace-with-real-bcrypt-hash

# 构建版本信息（可选，docker compose build 时注入）
# VERSION=1.0.0
# COMMIT=abc1234
# BUILT=2025-01-01T00:00:00Z
